{
  "expo": {
    "name": "Arena Master",
    "slug": "arena-master",
    "scheme": "arena-master",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/arena-master-app.png",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/arena-master-app.png",
        "backgroundColor": "#C5A85B"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.lldearaujo.arenamaster"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para definir o avatar do perfil."
        }
      ]
    ],
    "experiments": {},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2a03dbf-5c6a-431f-a88f-829207895039"
      }
    }
  }
}
