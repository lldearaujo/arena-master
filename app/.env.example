# Backend na LAN — usado pelo Expo Go / build nativo (opcional).
# No web em desenvolvimento, essa URL é ignorada; o app usa http://localhost:8000.
# EXPO_PUBLIC_API_URL=http://192.168.0.10:8000

# Só web: forçar outra base (ex.: API na LAN ou porta diferente da 8000).
# EXPO_PUBLIC_API_URL_WEB=http://192.168.0.10:8001
